#define ADAPTIVE_DELAY 200
#define ADAPTIVE_DELAY_FAST 155
#define FT 20


#define ZMK_MACRO_VF(name,...) \
	name: name { \
			compatible = "zmk,behavior-macro"; \
			#binding-cells = <0>; \
			wait-ms = <0>; \
			tap-ms = <10>; \
			__VA_ARGS__ \
		};

#define ZMK_MACRO_F(name,...) \
	name: name { \
			compatible = "zmk,behavior-macro"; \
			#binding-cells = <0>; \
			wait-ms = <10>; \
			tap-ms = <10>; \
			__VA_ARGS__ \
		};


#define AD_SNAME(x) ad ## x
#define AD_LNAME(x) adaptive ## x
#define AD_LBL(x) ADAPTIVE ## x
#define PRE_QUOTE(x) #x
#define QUOTE(x) PRE_QUOTE(x)

#define ZMK_ADAPTIVE(the_key,...) \
	AD_SNAME(the_key): AD_LNAME(the_key) { \
		compatible = "zmk,behavior-antecedent-morph"; \
		label = QUOTE(AD_LBL(the_key)); \
		#binding-cells = <0>; \
		max-delay-ms = <ADAPTIVE_DELAY>; \
		__VA_ARGS__ \
	};


/ { behaviors {
	ZMK_ADAPTIVE(_Q,
		defaults = <&kp Q>;
		antecedents = <E W>;
		bindings = <&m_dge>, <&m_dqt>;
        )

	ZMK_ADAPTIVE(_W,
		defaults = <&kp W>;
		antecedents = <E W>;
		bindings = <&m_dkk>, <&m_dqt>;
        )

	ZMK_ADAPTIVE(_E,
		defaults = <&kp E>;
		antecedents = <FSLH Q SEMI W>;
		bindings = <&kp B>, <&kp G>, <&m_gc>, <&m_ddw>;
        )

	ZMK_ADAPTIVE(_R,
		defaults = <&kp R>;
		antecedents = <E>;
		bindings = <&kp C>;
        )

	ZMK_ADAPTIVE(_O,
		defaults = <&kp O>;
		antecedents = <I P U>;
		bindings = <&m_mk>, <&kp L>, <&kp M>;
        )

	ZMK_ADAPTIVE(_P,
		defaults = <&kp P>;
		antecedents = <O>;
		bindings = <&kp O>;
        )

	ZMK_ADAPTIVE(_SEMI,
		defaults = <&kp SEMI>;
		antecedents = <A>;
		bindings = <&m_dga>;
        )

	ZMK_ADAPTIVE(_Z,
		defaults = <&kp Z>;
		antecedents = <C FSLH>;
		bindings = <&m_dgc>, <&kp B>;
        )

	ZMK_ADAPTIVE(_X,
		defaults = <&kp X>;
		antecedents = <Z>;
		bindings = <&m_dvy>;
        )

	ZMK_ADAPTIVE(_C,
		defaults = <&kp C>;
		antecedents = <Z>;
		bindings = <&kp G>;
        )

	ZMK_ADAPTIVE(_M,
		defaults = <&kp M>;
		antecedents = <FSLH Q>;
		bindings = <&kp J>, <&kp G>;
        )

	ZMK_ADAPTIVE(_DOT,
		defaults = <&kp DOT>;
		antecedents = <FSLH>;
		bindings = <&kp L>;
        )

	ZMK_ADAPTIVE(_FSLH,
		defaults = <&kp FSLH>;
		antecedents = <A C M S>;
		bindings = <&m_dba>, <&m_dbc>, <&m_djm>, <&m_dbs>;
        )


	hms_m_x: homerow_mod_x_macro {
		compatible = "zmk,behavior-hold-tap";
		label = "HOMEROW_MOD_SLOW_X_MACRO";
		#binding-cells = <2>;
		tapping-term-ms = <200>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&ad_X>;
	};
	
	hm_m_c: homerow_mod_c_macro {
		compatible = "zmk,behavior-hold-tap";
		label = "HOMEROW_MOD_SLOW_C_MACRO";
		#binding-cells = <2>;
		tapping-term-ms = <160>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&ad_C>;
	};


	hms_m_m: homerow_mod_m_macro {
		compatible = "zmk,behavior-hold-tap";
		label = "HOMEROW_MOD_SLOW_M_MACRO";
		#binding-cells = <2>;
		tapping-term-ms = <220>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&ad_M>;
	};

	hms_m_dot: homerow_mod_w_macro {
		compatible = "zmk,behavior-hold-tap";
		label = "HOMEROW_MOD_SLOW_W_MACRO";
		#binding-cells = <2>;
		tapping-term-ms = <240>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&ad_DOT>;
	};

	hms_m_lsrs: lsrs_m_macro {
		compatible = "zmk,behavior-hold-tap";
		label = "LSRS_SLOW_M_MACRO";
		#binding-cells = <2>;
		tapping-term-ms = <220>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&m_ls_rs>;
	};


	
	ZMK_MACRO_F(m_dba,
		bindings = <&kp BSPC &kp B &kp A>;
	)

	ZMK_MACRO_F(m_dbc,
		bindings = <&kp BSPC &kp B &kp C>;
	)
	
	ZMK_MACRO_F(m_dbs,
		bindings = <&kp BSPC &kp B &kp S>;
	)

	ZMK_MACRO_F(m_ddw,
		bindings = <&kp BSPC &kp D &kp W>;
	)

	ZMK_MACRO_F(m_djm,
		bindings = <&kp BSPC &kp J &kp M>;
	)

	ZMK_MACRO_F(m_dga,
		bindings = <&macro_tap_time 1>
			, <&macro_wait_time FT>
			, <&kp BSPC &kp G &kp A>;
	)

	ZMK_MACRO_F(m_dge,
		bindings = <&kp BSPC &kp G &kp E>;
	)

	ZMK_MACRO_F(m_dgc,
		bindings = <&kp BSPC &kp G &kp C>;
	)

	ZMK_MACRO_F(m_dvy,
		bindings = <&kp BSPC &kp V &kp Y>;
	)

	ZMK_MACRO_F(m_dg_gr,
		bindings = <&kp BSPC &kp G &kp GRAVE>;
	)

	ZMK_MACRO_F(m_dkk,
		bindings = <&kp BSPC &kp Y>;
	)

	ZMK_MACRO_F(m_dqt,
		bindings = <&kp BSPC &kp SQT>;
	)

	ZMK_MACRO_F(m_mk,
		bindings = <&kp M &kp K>;
	)

	ZMK_MACRO_F(m_gc,
		bindings = <&kp G &kp C>;
	)


	slad: adaptive_l {
		compatible = "zmk,behavior-sticky-key";
		label = "SL_AL";
		// quick-release;
		#binding-cells = <1>;
		release-after-ms = <ADAPTIVE_DELAY>;
		bindings = <&mo>;
	};
	
	slad_f: adaptive_l_fast {
		compatible = "zmk,behavior-sticky-key";
		label = "SL_AL_F";
		// quick-release;
		#binding-cells = <1>;
		release-after-ms = <ADAPTIVE_DELAY_FAST>;
		bindings = <&mo>;
	};

	ZMK_MACRO_VF(ak_Q,
		bindings = <&kp Q &slad AL_Q>;
	)

	ZMK_MACRO_VF(ak_W,
		bindings = <&kp W &slad AL_W>;
	)

	ZMK_MACRO_VF(ak_E,
		bindings = <&macro_tap_time 1>
				, <&macro_press &kp E>
				, <&macro_tap &slad AL_E>
				, <&macro_wait_time FT>
				, <&macro_release &kp E>;
	)

	ZMK_MACRO_VF(ak_R,
		bindings = <&kp R &slad AL_R>;
	)

	ZMK_MACRO_VF(ak_O,
		bindings = <&kp O &slad AL_O>;
	)

	ZMK_MACRO_VF(ak_P,
		bindings = <&kp P &slad AL_P>;
	)

	ZMK_MACRO_VF(ak_SEMI,
		bindings = <&kp SEMI &slad_f AL_SEMI>;
	)

	ZMK_MACRO_VF(ak_Z,
		bindings = <&kp Z &slad AL_Z>;
	)

	ZMK_MACRO_VF(ak_X,
		bindings = <&macro_tap_time 1>
				, <&macro_press &kp X>
				, <&macro_tap &slad AL_X>
				, <&macro_wait_time FT>
				, <&macro_release &kp X>;
	)

	ZMK_MACRO_VF(ak_C,
		bindings = <&macro_tap_time 1>
				, <&macro_press &kp C>
				, <&macro_tap &slad AL_C>
				, <&macro_wait_time FT>
				, <&macro_release &kp C>;
	)

	ZMK_MACRO_VF(ak_M,
		bindings = <&macro_tap_time 1>
				, <&macro_press &kp M>
				, <&macro_tap &slad AL_M>
				, <&macro_wait_time FT>
				, <&macro_release &kp M>;
	)

	ZMK_MACRO_VF(ak_FSLH,
		bindings = <&kp FSLH &slad AL_FSLH>;
	)

	ZMK_MACRO_VF(ak_DOT,
		bindings = <&kp DOT &slad AL_DOT>;
	)
}; };
