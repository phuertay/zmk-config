#define ZMK_MACRO_(name,...) \
	name: name { \
			compatible = "zmk,behavior-macro"; \
			#binding-cells = <0>; \
			wait-ms = <1>; \
			tap-ms = <10>; \
			__VA_ARGS__ \
		};

/ { behaviors {
	hms_m_lsrs: lsrs_m_macro {
		compatible = "zmk,behavior-hold-tap";
		#binding-cells = <2>;
		tapping-term-ms = <220>;
		quick-tap-ms = <0>;
		flavor = "balanced";
		bindings = <&kp>, <&m_ls_rs>;
	};
	
	ZMK_MACRO_(m_ls_rs,
		wait-ms = <40>;
		bindings = <&macro_press &kp LSHFT>,
				<&macro_tap &kp RSHFT>,
				<&macro_release &kp LSHFT>;
	)
		
	ZMK_MACRO_(m_eq_sum,
		bindings = <&kp RBKT &kp S &kp M &kp E &kp MINUS>;
	)
		
	ZMK_MACRO_(m_sum,
		bindings = <&kp S &kp M &kp E &kp MINUS>;
	)
	
	ZMK_MACRO_(m_9_16,
		bindings = <&macro_wait_time 50>,
				<&kp LALT>,
				<&macro_wait_time 30>,
				<&kp Q &kp J &kp SEMI &kp KP_N9 &kp TAB &kp KP_N1 &kp KP_N6 &kp ENTER &kp ESC>;
	)
	
	ZMK_MACRO_(m_9_16_steno,
		bindings = <&macro_wait_time 50>,
				<&kp LALT>,
				<&macro_wait_time 30>,
				<&kp Q &kp J &kp SEMI &kp LS(N1) &kp TAB &kp LS(N3) &kp LS(N6) &kp ENTER &kp ESC>;
	)
		
	ZMK_MACRO_(m_email_w,
		bindings = <&kp G &kp SEMI &kp M &kp K &kp A &kp GRAVE &kp J>,
				<&kp LS(I)>,
				<&kp T &kp J &kp S &kp J &kp GRAVE &kp V &kp SEMI>,
				<&kp W &kp C &kp COMMA &kp B &kp J &kp C>,
				<&kp I &kp V &kp COMMA &kp E>;
	)
		
	ZMK_MACRO_(m_email_g,
		bindings = <&kp G &kp SEMI &kp M &kp K &kp A &kp GRAVE &kp J &kp DOT>,
				<&kp LS(I)>,
				<&kp W &kp E &kp J &kp L &kp C>,
				<&kp I &kp V &kp COMMA &kp E>;
	)
		
	ZMK_MACRO_(m_email_w_old,
		bindings = <&kp G &kp SEMI &kp M &kp K &kp A &kp GRAVE &kp J>,
				<&kp LS(I)>,
				<&kp T &kp J &kp S &kp J &kp GRAVE &kp V &kp SEMI &kp J>,
				<&kp F &kp FSLH &kp L &kp S &kp COMMA &kp A &kp S>,
				<&kp I &kp V &kp COMMA &kp E>;
	)
		
	ZMK_MACRO_(m_email_ph,
		bindings = <&kp G &kp SEMI>,
				<&kp LS(I)>,
				<&kp T &kp J &kp S &kp J &kp GRAVE &kp V &kp SEMI>,
				<&kp W &kp C &kp COMMA &kp B &kp J &kp C>,
				<&kp I &kp V &kp COMMA &kp E>;
	)
	
	ZMK_MACRO_(m_phuerta,
		bindings = <&kp G &kp SEMI &kp M &kp K &kp A &kp GRAVE &kp J>;
	)
	
	ZMK_MACRO_(m_ph,
		bindings = <&kp LS(G) &kp K &kp F &kp A &kp COMMA>,
				<&kp SPACE>,
				<&kp LS(SEMI) &kp M &kp K &kp A &kp GRAVE &kp J>;
	)
	
	ZMK_MACRO_(m_pihy,
		bindings = <&kp LS(G) &kp K &kp F &kp A &kp COMMA>,
				<&kp SPACE>,
				<&kp LS(L) &kp I>,
				<&kp SPACE>,
				<&kp LS(SEMI) &kp M &kp K &kp A &kp GRAVE &kp J>,
				<&kp SPACE>,
				<&kp LS(DOT) &kp M &kp E &kp SEMI &kp J>;
	)
	
	ZMK_MACRO_(m_excel_go_to,
		bindings = <&kp RC(W)>,
				<&macro_press &mo DEFAULT_HD_2>,
				<&macro_pause_for_release>,
				<&macro_release &mo DEFAULT_HD_2>;
	)
	
	ZMK_MACRO_(m_c_spfn,
		wait-ms = <40>;
		bindings = <&macro_press &mo SPFN_HD &kp RCTRL>,
    				<&macro_pause_for_release>,
				<&macro_release &mo SPFN_HD &kp RCTRL>;
	)
	
	ZMK_MACRO_(m_paste_transp,
		wait-ms = <40>;
		bindings = <&kp RC(LA(FSLH)) &kp LA(FSLH) &kp K &kp ENTER>;
	)
	
	ZMK_MACRO_(m_equity,
		wait-ms = <40>;
		bindings = <&kp SPACE &kp LS(K)>,
				<&macro_wait_time 9>,
				<&kp O &kp M &kp L &kp GRAVE &kp DOT>;
	)
	
	ZMK_MACRO_(m_calc,
		bindings = <&macro_press &kp RGUI &kp RSHFT>,
				<&macro_tap &kp N3>,
				<&macro_release &kp RGUI &kp RSHFT>;
	)

	ZMK_MACRO_(m_las_n2,
		bindings = <&kp LALT>,
				<&macro_wait_time 15>,
				<&kp LS(N2)>;
	)

	ZMK_MACRO_(m_las_n3,
		bindings = <&kp LALT>,
				<&macro_wait_time 15>,
				<&kp LS(N3)>;
	)

	ZMK_MACRO_(m_las_n7,
		bindings = <&kp LALT>,
				<&macro_wait_time 15>,
				<&kp LS(N7)>;
	)
	
	ZMK_MACRO_(m_to_steno,
		bindings = <&to STENO, &kp steno_on>;
	)
	
	ZMK_MACRO_(m_from_steno,
		bindings = <&to DEFAULT_HD &kp steno_off>;
	)
	
	ZMK_MACRO_(m_to_steno_np_off,
		bindings = <&to STENO &kp steno_on &kp numpad_off>;
	)
	
	ZMK_MACRO_(m_from_steno_np_off,
		bindings = <&to DEFAULT_HD &kp steno_off &kp numpad_off>;
	)

	ZMK_MACRO_(m_plo_look,
		bindings = <&macro_press &kp PLV_PL &kp PLV_HL &kp PLV_RL &kp PLV_U &kp PLV_PR>,
				<&macro_release &kp PLV_PL &kp PLV_HL &kp PLV_RL &kp PLV_U &kp PLV_PR>;
	)

	ZMK_MACRO_(m_plo_add,
		bindings = <&macro_press &kp PLV_TL &kp PLV_KL &kp PLV_U &kp PLV_PR &kp PLV_TR>,
				<&macro_release &kp PLV_TL &kp PLV_KL &kp PLV_U &kp PLV_PR &kp PLV_TR>;
	)

	ZMK_MACRO_(m_pren,
		bindings = <&macro_press &kp PLV_PL &kp PLV_RL &kp PLV_E &kp PLV_PR &kp PLV_BR>,
				<&macro_release &kp PLV_PL &kp PLV_RL &kp PLV_E &kp PLV_PR &kp PLV_BR>;
	)

	ZMK_MACRO_(m_pren_s,
		bindings = <&macro_press &kp PLV_PL &kp PLV_RL &kp PLV_E &kp PLV_PR &kp PLV_BR &kp PLV_ST>,
				<&macro_release &kp PLV_PL &kp PLV_RL &kp PLV_E &kp PLV_PR &kp PLV_BR &kp PLV_ST>;
	)

	to_s: to_s {
	    compatible = "zmk,behavior-macro-two-param";
	    wait-ms = <7>;
	    tap-ms = <0>;
	    #binding-cells = <2>;
	    bindings = <&macro_param_2to1>
	        , <&macro_tap &kp MACRO_PLACEHOLDER>
		, <&macro_param_1to1>
	        , <&macro_tap &to MACRO_PLACEHOLDER>;
	};

	to_s_num: to_s_num {
	    compatible = "zmk,behavior-macro-one-param";
	    wait-ms = <0>;
	    tap-ms = <0>;
	    #binding-cells = <1>;
	    bindings = <&macro_tap &kp numpad_on>
		, <&macro_param_1to1>
	        , <&macro_tap &to MACRO_PLACEHOLDER>;
	};

	tog_s: tog_s {
	    compatible = "zmk,behavior-macro-two-param";
	    wait-ms = <7>;
	    tap-ms = <0>;
	    #binding-cells = <2>;
	    bindings = <&macro_param_2to1>
	        , <&macro_tap &kp MACRO_PLACEHOLDER>
		, <&macro_param_1to1>
	        , <&macro_tap &tog MACRO_PLACEHOLDER>;
	};

	tog_s_num: tog_s_num {
	    compatible = "zmk,behavior-macro-one-param";
	    wait-ms = <0>;
	    tap-ms = <0>;
	    #binding-cells = <1>;
	    bindings = <&macro_tap &kp numpad_on>
		, <&macro_param_1to1>
	        , <&macro_tap &tog_on MACRO_PLACEHOLDER>;
	};

	mo_s_num: mo_s_num {
	    compatible = "zmk,behavior-macro-one-param";
	    wait-ms = <0>;
	    tap-ms = <0>;
	    #binding-cells = <1>;
	    bindings = <&macro_tap &kp numpad_on>
		, <&macro_param_1to1>
	        , <&macro_press &mo MACRO_PLACEHOLDER>
	        , <&macro_pause_for_release>
	        , <&macro_param_1to1>
	        , <&macro_release &mo MACRO_PLACEHOLDER>
	        , <&macro_tap &kp numpad_off>;
	};
}; };
